# 应用配置
APP_NAME=智能渔场环境控制监测系统
APP_VERSION=1.0.0
APP_ENV=development

# 服务器配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/fishfarm
DATABASE_ECHO=false

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# MQTT配置
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=fishfarm

# 数据保留配置
REALTIME_DATA_RETENTION_DAYS=7
HISTORY_DATA_RETENTION_DAYS=365

# 预警配置
DEFAULT_ALARM_LEVEL=提醒
NOTIFICATION_METHODS='["推送", "短信", "电话"]'

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# 安全配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS='.jpg,.jpeg,.png,.pdf'

# CORS配置
CORS_ORIGINS='["*"]'

# 时区配置
TIMEZONE=Asia/Shanghai
